// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
	{
		"label": "Build & Debug Example: Transform",
		"build": {
			"command": "cargo",
			"args": ["build", "--example", "transform"]
		},
		"program": "$ZED_WORKTREE_ROOT/target/debug/examples/transform",
		"args": [
			"--mode",
			"transport", // or "morph"
			"$ZED_WORKTREE_ROOT/vendor/flucoma-core/Resources/AudioFiles/Olencki-TenTromboneLongTones-M.wav",
			"$ZED_WORKTREE_ROOT/vendor/flucoma-core/Resources/AudioFiles/Tremblay-SlideChoirAdd-M.wav",
			"$ZED_WORKTREE_ROOT/target/transform-result.wav"
		],
		"sourceLanguages": ["rust"],
		"request": "launch",
		"adapter": "CodeLLDB"
	},

	{
		"label": "Build & Debug Example: Unique-Slices",
		"build": {
			"command": "cargo",
			"args": ["build", "--example", "unique-slices"]
		},
		"program": "$ZED_WORKTREE_ROOT/target/debug/examples/unique-slices",
		"args": [
			"$ZED_WORKTREE_ROOT/vendor/flucoma-core/Resources/AudioFiles/Nicol-LoopE-M.wav"
		],
		"sourceLanguages": ["rust"],
		"request": "launch",
		"adapter": "CodeLLDB"
	}
]
